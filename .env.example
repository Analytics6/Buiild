# OpenAI / LLM
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDINGS_PROVIDER=openai

# Redis (sessions + cache + rate limiting)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# Database (leave empty for SQLite, or set PostgreSQL URL)
DATABASE_URL=
DB_PATH=./data/app.db

# ChromaDB persistence
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=complaints
DATA_DIR=./data/complaints

# Security
JWT_SECRET=generate-a-long-random-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Session TTL (seconds)
SESSION_TTL_SECONDS=86400
SESSION_REFRESH_TTL_SECONDS=604800

# Cache TTL (seconds)
CACHE_TTL_SECONDS=3600
EMBEDDING_CACHE_TTL_SECONDS=86400
RAG_CACHE_TTL_SECONDS=1800

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# CORS (JSON array of origins, e.g. ["*"] or ["http://localhost:5173"])
CORS_ORIGINS=["*"]

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=complaint-rag
